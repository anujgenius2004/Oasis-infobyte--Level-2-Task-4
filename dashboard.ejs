<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>Oasis infobyte</title>
</head>
<body class="bg-zinc-950 text-zinc-300 font-mono">


    <nav class="border-b border-zinc-800 p-4 flex justify-between items-center px-10 bg-black/50 backdrop-blur-md sticky top-0 z-50">
        <div class="flex items-center gap-3">
            <div class="w-3 h-3 bg-cyan-500 rounded-full animate-pulse"></div>
            <h1 class="text-xl font-black text-white tracking-tighter italic">Oasis infobyte</h1>
        </div>
        <a href="/logout" class="text-[10px] bg-zinc-900 border border-zinc-700 px-4 py-2 rounded hover:bg-red-600 hover:text-white transition font-bold uppercase tracking-widest">
            Terminate_Session
        </a>
    </nav>

    <main class="p-8 max-w-6xl mx-auto">
       
        <div class="mb-10 flex justify-between items-end">
            <div>
                <p class="text-cyan-500 text-xs font-bold mb-1">SYSTEM_ACCESS: GRANTED</p>
                <h2 class="text-4xl font-black text-white uppercase tracking-tighter">Command_Center</h2>
            </div>
            <div class="text-right text-[10px] text-zinc-500">
                <p>LATENCY: 24ms</p>
                <p>UPTIME: 99.9%</p>
            </div>
        </div>

        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-2xl hover:border-cyan-500/50 transition">
                <h3 class="text-zinc-500 text-[10px] font-bold uppercase mb-4">Network_Relay</h3>
                <p class="text-3xl font-black text-white">ONLINE</p>
                <p class="text-cyan-600 text-[10px] mt-2">MESH_STANDBY</p>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-2xl hover:border-cyan-500/50 transition">
                <h3 class="text-zinc-500 text-[10px] font-bold uppercase mb-4">G-Force_Sensors</h3>
                <p class="text-3xl font-black text-white">ACTIVE</p>
                <p class="text-zinc-600 text-[10px] mt-2">0.98G (NORMAL)</p>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-2xl hover:border-cyan-500/50 transition">
                <h3 class="text-zinc-500 text-[10px] font-bold uppercase mb-4">SOS_Fallback</h3>
                <p class="text-3xl font-black text-white">READY</p>
                <p class="text-zinc-600 text-[10px] mt-2">GSM_CONTROL_CHANNEL</p>
            </div>
        </div>

        
        <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-10 text-center relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-cyan-500/50 shadow-[0_0_15px_cyan]"></div>
            <h2 class="text-6xl font-black text-white mb-4 opacity-10">SYSTEM_READY</h2>
            <p class="text-zinc-400 max-w-md mx-auto mb-8">THIS PROJECT WAS MADE TO DEMONSTRATE THE USE OF AUTHENTICATION AND SESSION MANAGEMENT IN A WEB APPLICATION.</p>
            <button class="border border-cyan-500/50 text-cyan-500 px-8 py-3 rounded-full text-xs font-black uppercase tracking-widest hover:bg-cyan-500 hover:text-black transition">
                Initialize_Scan
            </button>
        </div>
    </main>

</body>
</html>